generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  phone     String?
  subject   String
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Assessment {
  id              String   @id @default(cuid())
  companyName     String?
  contactEmail    String?
  sector          String?
  totalScore      Float
  maxScore        Float
  percentScore    Float
  maturityLevel   String
  categoryScores  String
  recommendations String
  createdAt       DateTime @default(now())
}
