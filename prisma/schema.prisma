generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/gertec_consultoria_ti/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  phone     String?
  subject   String
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Assessment {
  id              String   @id @default(cuid())
  companyName     String?
  contactEmail    String?
  sector          String?
  totalScore      Float
  maxScore        Float
  percentScore    Float
  maturityLevel   String
  categoryScores  String
  recommendations String
  createdAt       DateTime @default(now())
}
